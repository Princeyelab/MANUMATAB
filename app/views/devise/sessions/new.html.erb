<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-4">

      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h2 class="text-center mb-4">Connexion</h2>

          <%# L'option turbo: false est cruciale pour éviter le bug de connexion %>
          <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { data: { turbo: false } }) do |f| %>

            <div class="form-inputs">
              <%= f.input :email,
                          required: false,
                          autofocus: true,
                          input_html: { autocomplete: "email", class: "form-control mb-3" } %>

              <%= f.input :password,
                          required: false,
                          input_html: { autocomplete: "current-password", class: "form-control mb-3" } %>

              <% if devise_mapping.rememberable? %>
                <div class="mb-3">
                  <%= f.input :remember_me, as: :boolean, wrapper: :vertical_boolean %>
                </div>
              <% end %>
            </div>

            <div class="form-actions d-grid gap-2">
              <%= f.button :submit, "Se connecter", class: "btn btn-primary btn-lg" %>
            </div>

          <% end %>

          <hr class="my-4">

          <div class="text-center small">
            <%= render "devise/shared/links" %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
