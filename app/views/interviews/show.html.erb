<div class="container mt-5">

  <!-- Titre -->
  <div class="mb-4">
    <h2><%= @interview.job_title %></h2>
    <p class="text-muted"><%= @interview.job_description %></p>
    <hr>
  </div>

  <!-- Zone des messages -->
  <div class="card">
    <div class="card-body" style="height: 400px; overflow-y: scroll;" id="messages">

      <% @messages.each do |message| %>
        <% if message.user == current_user %>
          <!-- Message utilisateur -->
          <div class="d-flex justify-content-end mb-3">
            <div class="bg-primary text-white p-3 rounded" style="max-width: 70%;">
              <%= message.content %>
              <div class="small text-end mt-1">
                <%= message.created_at.strftime("%H:%M") %>
              </div>
            </div>
          </div>
        <% else %>
          <!-- Message coach / bot -->
          <div class="d-flex justify-content-start mb-3">
            <div class="bg-light p-3 rounded border" style="max-width: 70%;">
              <%= message.content %>
              <div class="small text-muted mt-1">
                <%= message.created_at.strftime("%H:%M") %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>

    </div>
  </div>

  <!-- Formulaire -->
  <div class="mt-3">
    <%= simple_form_for [@chat, @new_message] do |f| %>
      <div class="input-group">
        <%= f.input :content,
                    label: false,
                    placeholder: "Écrivez votre message...",
                    input_html: { class: "form-control" } %>

        <button class="btn btn-primary" type="submit">
          Envoyer
        </button>
      </div>
    <% end %>
  </div>

</div>
